# Ignore node_modules directory as dependencies are handled by Homey app store
node_modules/

# Ignore logs and temporary files
*.log
*.tmp
*.swp

# Ignore IDE specific files and directories
.vscode/
.idea/
.cursor/

# Ignore OS-specific metadata (any directory)
.DS_Store
**/.DS_Store
._*
**/._*
Thumbs.db
desktop.ini

# Ignore test files and directories
test/
tests/
**/__tests__/
**/__mocks__/
*.test.ts
*.spec.ts
jest.config.ts

# Ignore Git and version control specific files
.git/
.gitignore
.gitattributes

# Build and configuration files
.env
.eslintrc.json
package-lock.json
tsconfig.json
tsconfig.*.json

# Repo documentation (store listing uses README.txt)
README.md
.npmignore
