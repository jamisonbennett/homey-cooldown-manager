{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "outDir": ".homeybuild/",
    "lib": ["ES2023"],
    "types": ["node"]
  },
  "include": [
    "api.ts",
    "app.ts",
    "drivers/**/*.ts",
    "lib/**/*.ts",
    "settings/load-cooldown-state.js",
    "settings/format-local-datetime.js"
  ],
  "exclude": ["node_modules", ".homeybuild", "**/*.test.ts", "**/*.test.js"]
}
